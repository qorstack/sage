# precept project config — drop at repo root and commit.
# Required to link this repo to a workspace.

workspace = "my-product"      # required — which workspace this repo belongs to
repo_name = "aaa-api"         # required — explicit name (not auto-detected from folder)
role      = "backend"         # optional — backend / frontend / worker / shared / infra
domains   = ["payment", "auth"]   # optional

# Optional — when true, AI-written business_context memory is approved at save
# time (tagged approved_by="ai-auto") instead of landing as Pending. Humans
# curate by editing/deleting on the dashboard. Default: false (human approves).
# auto_approve_ai_memory = true

[database]                    # optional — overrides ~/.precept.config
host     = "localhost"
port     = 55432              # matches quickstart's POSTGRES_PORT (avoids clashing with a system Postgres on 5432)
user     = "precept"
password = "precept"
db       = "precept"
schema   = "public"

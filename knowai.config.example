# knowai project config — drop at repo root and commit.
# Required to link this repo to a workspace.

workspace = "my-product"      # required — which workspace this repo belongs to
repo_name = "aaa-api"         # required — explicit name (not auto-detected from folder)
role      = "backend"         # optional — backend / frontend / worker / shared / infra
domains   = ["payment", "auth"]   # optional

[database]                    # optional — overrides ~/.knowai.config
host     = "localhost"
port     = 5432
user     = "knowai"
password = "knowai"
db       = "knowai"
schema   = "public"
